{
  "description": "Agent Instruction Manager - Automatically manages Claude.md and Agents.md files based on session state",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/workflows/agent-instruction-manager/.claude/hooks/preSession.sh \"$PWD\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/workflows/agent-instruction-manager/.claude/hooks/postSession.sh \"$PWD\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}